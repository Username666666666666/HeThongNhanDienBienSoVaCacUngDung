{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns", "deno.window"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noImplicitAny": false,
    "allowJs": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-unused-vars",
        "jsx-button-has-type",
        "no-explicit-any",
        "require-await"
      ]
    }
  },
  "imports": {
    "std/": "https://deno.land/std@0.177.0/",
    "resend": "npm:resend@3",
    "react": "npm:react@^18",
    "react-dom": "npm:react-dom@^18",
    "supabase-js": "npm:@supabase/supabase-js@2"
  }
}